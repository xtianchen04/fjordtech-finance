# ComplyHub — variables d'environnement Supabase
#
# 1. Copiez ce fichier en .env.local :  cp .env.local.example .env.local
# 2. Remplacez les valeurs ci-dessous par celles de votre projet Supabase
#    (Supabase → Settings → API)
# 3. Redémarrez le serveur Vite après toute modification de .env.local
#
# IMPORTANT : ces variables DOIVENT commencer par VITE_ pour être exposées au client.
# Ne committez JAMAIS .env.local (il est déjà dans .gitignore).

VITE_SUPABASE_URL=https://VOTRE_PROJET.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...VOTRE_CLE_ANON...
